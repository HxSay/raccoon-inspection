{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "java: compile drone module",
      "type": "shell",
      "command": "mvn",
      "args": [
        "-pl",
        "raccoon-cloud/raccoon-cloud-drone",
        "-am",
        "compile",
        "-DskipTests"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "maven: drone spring-boot:run",
      "type": "shell",
      "command": "mvn",
      "args": [
        "-pl",
        "raccoon-cloud/raccoon-cloud-drone",
        "-am",
        "spring-boot:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
